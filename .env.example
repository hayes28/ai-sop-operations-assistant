# Copy to .env and fill in values. Never commit .env or expose keys in the browser.

# Google Gemini (server-side only — never add to app.js or index.html)
GEMINI_API_KEY=your_gemini_api_key_here
# If you hit free-tier quota on one model, try: gemini-2.0-flash-lite or gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Conservative generation defaults (lower = cheaper / shorter responses)
MAX_OUTPUT_TOKENS=1024
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.85
GEMINI_TOP_K=32

# Required shared secret — users enter this in the app header before AI generate
ACCESS_CODE=change-me-to-a-strong-passphrase

# Server
PORT=3000

# Per-request input cap (characters)
MAX_INPUT_LENGTH=6000

# Rate limit: max AI requests per IP per rolling window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# In-memory daily cap per IP (UTC day). Resets when the server restarts or at midnight UTC.
DAILY_REQUEST_CAP=50
