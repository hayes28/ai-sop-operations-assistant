# Copy to .env and fill in values. Never commit .env or expose keys in the browser.

# Google Gemini (server-side only)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Shared secret — users enter this in the app before generating
ACCESS_CODE=change-me-to-a-strong-passphrase

# Server
PORT=3000

# Cost / abuse controls
MAX_INPUT_LENGTH=8000
MAX_OUTPUT_TOKENS=2048

# Rate limit: max requests per IP per window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=15
